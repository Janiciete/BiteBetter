  "pregnancy_warnings": {
    "raw_fish": {
      "triggers": ["sushi", "sashimi", "raw fish", "raw salmon", "raw tuna", "ceviche", "tartare", "poke bowl", "raw ahi"],
      "message": "Raw fish is not recommended during pregnancy due to risk of listeria and parasites."
    },
    "raw_eggs": {
      "triggers": ["raw egg", "runny yolk", "soft boiled", "hollandaise", "aioli", "caesar dressing", "sunny side up", "over easy"],
